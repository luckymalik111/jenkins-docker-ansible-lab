pipeline {
    agent any

    stages {
        stage('Run Ansible Playbook') {
            steps {
                withEnv(["ANSIBLE_ROLES_PATH=${env.WORKSPACE}/ansible/roles"]) {
                    ansiblePlaybook(
                        playbook: 'ansible/playbooks/deploy-web.yml',
                        inventory: 'ansible/inventory/hosts.ini',
                        colorized: true
                    )
                }
            }
        }
    }
}
