pipeline {
    agent any

    stages {
        stage('Run Ansible Playbook') {
            steps {
                withEnv(['ANSIBLE_ROLES_PATH=/workspace/ansible/roles']) {
                    ansiblePlaybook(
                        playbook: '/workspace/ansible/playbooks/deploy-web.yml',
                        inventory: '/workspace/ansible/inventory/hosts.ini',
                        colorized: true
                    )
                }
            }
        }
    }
}
